# =============================================================
# kluky-setup configuration
# Copy this file to .env and fill in the values.
# =============================================================

# --- Required: API Keys ---

# ElevenLabs API key (STT and TTS)
ELEVENLABS_API_KEY=

# OpenAI API key (used by kluky_mcp indexer)
OPENAI_API_KEY=

# --- Required: Database ---

# Shared by kluky_mcp and google_workspace_sync
DB_PASSWORD=

# --- Required: Google Workspace ---

GOOGLE_DRIVE_DOCUMENTS_FOLDER_ID=
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_RANGE=

# --- Optional: OpenCode Custom Provider (OpenAI-compatible) ---

# If OPENCODE_PROVIDER_BASE_URL is set, OPENCODE_PROVIDER_MODELS and
# OPENCODE_PROVIDER_API_KEY MUST also be filled. start.sh will then inject a
# provider block into opencode.json and pre-select the first model, so you
# won't need to run /connect in the OpenCode TUI.

# If OPENCODE_PROVIDER_BASE_URL is empty, no provider is written and you can
# connect a provider interactively from the OpenCode TUI instead.
# OPENCODE_PROVIDER_BASE_URL=
# OPENCODE_PROVIDER_MODELS=modelname1,modelname2,modelname3...(replace_this_with_actual_model_names)
# OPENCODE_PROVIDER_API_KEY=

# --- Optional: Database (override if not using default Supabase) ---

# DB_HOST=
# DB_PORT=5432
# DB_NAME=
# DB_USER=
# DB_SSLMODE=prefer

# --- Optional: Voice / TTS ---

# ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
# ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
# ELEVENLABS_STT_MODEL_ID=scribe_v1
# STT_LANGUAGE=sk

# --- Optional: App Settings ---

# API_HOST=0.0.0.0
# API_PORT=8321
# WAKEWORD_MODEL_NAME=hey_kluky
# PAGEINDEX_MODEL=gpt-4.1-nano-fiit

